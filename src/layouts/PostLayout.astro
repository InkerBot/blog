---
import BaseLayout from './BaseLayout.astro';
import { formatDate, isoDate } from '../utils/date.ts';
import { tagSlug } from '../utils/posts.ts';

interface Props {
  title: string;
  date: Date;
  tags?: string[];
  description?: string;
}

const { title, date, tags = [], description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <a href="/posts/" class="back-link">← 所有文章</a>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={isoDate(date)}>发布于 {formatDate(date)}</time>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <div class="post-tags">
          <ul class="tag-list">
            {tags.map((tag) => (
              <li>
                <a class="tag" href={`/tags/${tagSlug(tag)}/`}>
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </article>
</BaseLayout>
