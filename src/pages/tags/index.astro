---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllTags, tagSlug } from '../../utils/posts.ts';

const tags = [...(await getAllTags()).entries()].sort(
  (a, b) => b[1].length - a[1].length,
);
---

<BaseLayout title="标签">
  <p class="section-label">标签 · {tags.length} 个</p>
  <ul class="tag-list">
    {
      tags.map(([tag, posts]) => (
        <li>
          <a class="tag" href={`/tags/${tagSlug(tag)}/`}>
            #{tag} <span style="opacity:.6">{posts.length}</span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
