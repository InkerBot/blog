---
import { SITE } from '../consts.ts';
const year = new Date().getFullYear();
const build = __BUILD__;
const commitUrl =
  build.commit && SITE.repo ? `${SITE.repo}/commit/${build.commit}` : null;
---

<footer class="site-footer wrap">
  <span>
    {year} © {SITE.author}
    <span class="build-info">
      · Build #{build.number} ·{' '}
      {
        commitUrl ? (
          <a href={commitUrl} title={build.commit}>
            {build.short}
          </a>
        ) : (
          <span title={build.commit}>{build.short}</span>
        )
      }
    </span>
  </span>
  <span>
    <a href="/rss.xml">RSS</a> · <a href="/about/">关于</a>
  </span>
</footer>
